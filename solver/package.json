{
  "name": "ez-path-solver",
  "version": "0.1.0",
  "description": "EZ-Path Solver Framework - Intent-based route execution and settlement",
  "type": "module",
  "main": "dist/start.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/start.ts",
    "solver": "node dist/start.js",
    "test": "tsx --test src/**/*.test.ts",
    "types": "tsc --noEmit",
    "contracts:compile": "solc --optimize --bin --abi contracts/*.sol"
  },
  "dependencies": {
    "viem": "^2.49.3",
    "ethers": "^6.13.0",
    "axios": "^1.7.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.8.3",
    "tsx": "^4.22.3"
  }
}
