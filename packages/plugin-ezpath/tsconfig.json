{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "CommonJS",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022"],
    "outDir":            "./dist",
    "declaration":       true,
    "strict":            true,
    "skipLibCheck":      true,
    "esModuleInterop":   true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
