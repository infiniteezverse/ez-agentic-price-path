# EZ-Path Treasury Bot Configuration

# Base mainnet RPC endpoint (required)
BASE_RPC_URL=https://mainnet.base.org

# Treasury wallet address that receives LP tokens (required)
TREASURY_ADDRESS=0x13dDE704389b1118B20d2BCc6D3Ace749600e2ad

# Relayer private key for signing onchain transactions (required)
# Must have ETH on Base for gas
RELAYER_PRIVATE_KEY=0x

# Optional: Dune Analytics API
DUNE_API_KEY=
DUNE_DASHBOARD_ID=

# Optional: Slack webhook for alerts
SLACK_WEBHOOK=
